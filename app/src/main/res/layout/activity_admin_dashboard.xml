<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_page">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/background_primary">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tick"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="it"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Admin"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin · Sarah"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/border_light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Total events -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="142"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total events"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Bookings -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_green"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3,861"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/stat_green_text" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bookings"
                        android:textSize="11sp"
                        android:textColor="@color/stat_green_text"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Cancelled -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_amber"
                    android:padding="12dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/stat_amber_text" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancelled"
                        android:textSize="11sp"
                        android:textColor="@color/stat_amber_text"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Upcoming events header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upcoming events"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/btn_add_event"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="+ Add event"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_green"
                    android:background="@drawable/bg_button_primary_small"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

            <!-- Event rows -->

            <!-- Event 1 -->
            <LinearLayout
                android:id="@+id/row_event_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@color/background_primary">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_event_icon_concert" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🎵"
                        android:textSize="16sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jazz Night Live"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 22 · Montreal · 248 tickets sold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_edit_event_1"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Edit"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_action_btn"
                    android:layout_marginEnd="6dp"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

                <Button
                    android:id="@+id/btn_cancel_event_1"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Cancel"
                    android:textSize="11sp"
                    android:textColor="@color/danger_text"
                    android:background="@drawable/bg_action_btn_danger"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/border_light" />

            <!-- Event 2 -->
            <LinearLayout
                android:id="@+id/row_event_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@color/background_primary">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_event_icon_sports" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="⚽"
                        android:textSize="16sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CF Montreal vs TOR"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 25 · Stade Saputo · 1,204 tickets sold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_edit_event_2"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Edit"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_action_btn"
                    android:layout_marginEnd="6dp"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

                <Button
                    android:id="@+id/btn_cancel_event_2"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Cancel"
                    android:textSize="11sp"
                    android:textColor="@color/danger_text"
                    android:background="@drawable/bg_action_btn_danger"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/border_light" />

            <!-- Event 3 -->
            <LinearLayout
                android:id="@+id/row_event_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@color/background_primary">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_event_icon_movie" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🎬"
                        android:textSize="16sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cinema Paradiso"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 28 · Cineplex Odeon · 87 tickets sold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_edit_event_3"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_action_btn"
                    android:text="Edit"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_cancel_event_3"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Cancel"
                    android:textSize="11sp"
                    android:textColor="@color/danger_text"
                    android:background="@drawable/bg_action_btn_danger"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/border_light" />

            <!-- Event 4 -->
            <LinearLayout
                android:id="@+id/row_event_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@color/background_primary">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_event_icon_travel" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="✈️"
                        android:textSize="16sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MTL → NYC Express"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apr 1 · Gare Centrale · 312 tickets sold"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_edit_event_4"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Edit"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_action_btn"
                    android:layout_marginEnd="6dp"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

                <Button
                    android:id="@+id/btn_cancel_event_4"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Cancel"
                    android:textSize="11sp"
                    android:textColor="@color/danger_text"
                    android:background="@drawable/bg_action_btn_danger"
                    app:backgroundTint="@null"
                    style="@style/Widget.AppCompat.Button.Borderless" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>