<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tick"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="it"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create account"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book tickets in seconds. Already have one? Sign in below."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="20dp" />

        <!-- Register / Sign in toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_toggle_container"
            android:padding="4dp"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_tab_register"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Register"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_toggle_active"
                app:backgroundTint="@null"
                style="@style/Widget.AppCompat.Button.Borderless" />

            <Button
                android:id="@+id/btn_tab_signin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Sign in"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@android:color/transparent"
                style="@style/Widget.AppCompat.Button.Borderless" />

        </LinearLayout>

        <!-- Role selector label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I am a…"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="10dp" />

        <!-- Role cards row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Customer card (selected by default) -->
            <LinearLayout
                android:id="@+id/card_customer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_role_card_selected"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_green" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="👤"
                        android:textSize="18sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/lbl_customer_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse &amp; book tickets"
                    android:textSize="11sp"
                    android:textColor="@color/green_dark"
                    android:gravity="center"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Admin card -->
            <LinearLayout
                android:id="@+id/card_admin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_role_card_default"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_gray" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🛠"
                        android:textSize="18sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/lbl_admin_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Administrator"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage events &amp; settings"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Admin info banner -->
        <LinearLayout
            android:id="@+id/banner_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_info_banner"
            android:padding="12dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ"
                android:textSize="14sp"
                android:textColor="@color/blue_dark"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Admin accounts require an organisation access code provided by your system administrator."
                android:textSize="12sp"
                android:textColor="@color/blue_dark"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- ===== REGISTER FIELDS ===== -->
        <LinearLayout
            android:id="@+id/layout_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email address"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="5dp" />
            <EditText
                android:id="@+id/et_email_register"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="jane@email.com"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="13sp"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="5dp" />
            <EditText
                android:id="@+id/et_password_register"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="Min. 8 characters"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <!-- Org code (admin only) -->
            <LinearLayout
                android:id="@+id/layout_org_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organisation access code"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="5dp" />
                <EditText
                    android:id="@+id/et_org_code"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:hint="e.g. ORG-XXXX-XXXX"
                    android:background="@drawable/bg_input"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="13sp"
                    android:inputType="textCapCharacters"
                    android:singleLine="true"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ===== SIGN IN FIELDS ===== -->
        <LinearLayout
            android:id="@+id/layout_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email address"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="5dp" />
            <EditText
                android:id="@+id/et_email_login"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="jane@email.com"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="13sp"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="5dp" />
            <EditText
                android:id="@+id/et_password_login"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:hint="Your password"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />


        </LinearLayout>
        <Button
            android:id="@+id/btn_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textSize="13sp"
            android:textColor="@color/green_primary"
            android:layout_gravity="end"
            android:background="@android:color/transparent"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:layout_marginTop="4dp"/>

        <!-- Submit -->
        <Button
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sign in"
            android:textSize="14sp"
            android:textColor="@color/text_on_green"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By registering you agree to our Terms of Service and Privacy Policy."
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>
</ScrollView>